# ---------------------------------------------------------------
# Music Catalog (External)
# The tracks table is backed by a ~500GB catalog imported via
# the ETL pipeline in migrations/. Solr indexes this catalog
# for full-text search. You must load your own catalog data
# into Postgres and Solr before search will return results.
# ---------------------------------------------------------------

# ---------------------------------------------------------------
# Firebase Credentials
# Place your Firebase Admin SDK JSON at the project root and
# name it to match the GOOGLE_APPLICATION_CREDENTIALS path.
# Do NOT commit this file. It is excluded via .gitignore.
# ---------------------------------------------------------------

# PostgreSQL Database
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=
DB_NAME=bluppi_music
DB_PORT=5432
CHAT_DB_NAME=bluppi_chat

# Test Database
TEST_DB_HOST=localhost
TEST_DB_USER=postgres
TEST_DB_PASSWORD=
TEST_DB_NAME=bluppi_test
TEST_DB_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Solr (indexes the external music catalog for full-text search)
SOLR_URL=http://localhost:8983/solr/tracks

# Memgraph
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USER=
MEMGRAPH_PASS=

# Firebase
GOOGLE_APPLICATION_CREDENTIALS=/app/firebase-credentials.json

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# Auth
ALLOW_MOCK_AUTH=false

# TLS
TLS_CERT_FILE=certs/server.crt
TLS_KEY_FILE=certs/server.key

# Gateway
GATEWAY_PORT=:50050
PRESENCE_INTERNAL_URL=localhost:50051
